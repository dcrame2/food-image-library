# Serper.dev API key (Google image search via Serper — free 2,500/month)
# Sign up at https://serper.dev. No credit card needed.
SERPER_API_KEY=

# fal.ai API key (primary background removal engine: BiRefNet v2, ~half a
# cent per image). Get a key at https://fal.ai/dashboard/keys
FAL_KEY=

# remove.bg API key (fallback engine, ~$0.20 per image)
# Get a key at https://www.remove.bg/api
# If both are unset, the app falls back to the free local @imgly model.
REMOVE_BG_API_KEY=

# Supabase (shared project with the Cutout Library mobile app)
NEXT_PUBLIC_SUPABASE_URL=https://lqlcqrnyunmjtdvjqftg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only. Supabase dashboard > Project Settings > API Keys >
# create/copy a secret key (sb_secret_...). Never expose to the browser.
# (The legacy service_role JWT also works via SUPABASE_SERVICE_ROLE_KEY.)
SUPABASE_SECRET_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
# $60/year price on the same Pro product (shown as $5/mo billed yearly)
STRIPE_PRICE_PRO_YEARLY=price_...

# Base URL of this deployment (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to false in production if the local @imgly ONNX engine cannot run there
# (e.g. serverless bundle size limits). Free-tier adds then use remove.bg.
BG_ENGINE_IMGLY_ENABLED=true
