# Serper.dev API key (Google image search via Serper — free 2,500/month)
# Sign up at https://serper.dev. No credit card needed.
SERPER_API_KEY=

# remove.bg API key (best-quality background removal)
# Free tier: 50 images/month. Get a key at https://www.remove.bg/api
# If unset, the app falls back to the free local @imgly model.
REMOVE_BG_API_KEY=
